# =============================================================================
# Dependency Map — shared environment template (repo root)
#
# Frontend: repo root .env is loaded by Next (see frontend/next.config.ts), or copy this block to frontend/.env.local
# Backend: FastAPI loads repo-root `.env` then `backend/.env` (see backend/app/config.py); a single root `.env` with this block is enough.
# Do not put service-role or server-only secrets in frontend/.env.local.
# =============================================================================

# --- Frontend (Next.js) — use as frontend/.env.local ---

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# FastAPI base URL (browser + server in dev)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Site origin for auth redirects (password reset). Falls back to window.location.origin in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: server-only override for server components / actions
# API_URL=http://127.0.0.1:8000

# --- Backend (FastAPI) — use as backend/.env ---

APP_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Supabase (service role for API/worker — never expose to the browser)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Settings → API → JWT Secret (verify user JWTs from the web app)
SUPABASE_JWT_SECRET=your_jwt_secret

# GitHub App (private key PEM; use \n for newlines in a single-line env var)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# GitHub App webhook signing secret (optional until webhooks are enabled)
GITHUB_WEBHOOK_SECRET=

# Redis + Celery (optional; docker-compose sets these for worker)
REDIS_URL=redis://localhost:6379/0
# Set true when running API + celery worker (see docker-compose.yml)
USE_CELERY=false

# Pepper for hashing API keys (Phase 5)
API_KEY_PEPPER=change-me-in-production

# --- Offline CPG scorer / reasoner (optional; used by `python -m cpg_builder` CLI and workers) ---
# CPG_REASONER_PROVIDER=stub|openai|gemini
# CPG_REASONER_OPENAI_API_KEY=  # or reuse OPENAI_API_KEY
# CPG_REASONER_OPENAI_BASE_URL=https://api.openai.com/v1
# CPG_REASONER_OPENAI_MODEL=gpt-4o-mini
# CPG_REASONER_GEMINI_API_KEY=
# CPG_REASONER_GEMINI_MODEL=gemini-2.0-flash
# CPG_REASONER_HTTP_TIMEOUT_SEC=120
# CPG_REASONER_TRAINING_JSONL=/path/to/append_only_training.jsonl
# CPG_RANKER_BACKEND=heuristic|graphcodebert
# CPG_GRAPHCODEBERT_LOCAL_DIR=/path/to/finetuned-checkpoint-dir
